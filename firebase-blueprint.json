{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A user's note document.",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "The text content of the note"
        },
        "lastUpdated": {
          "type": "number",
          "description": "Timestamp of the last update"
        }
      },
      "required": ["content", "lastUpdated"]
    }
  },
  "firestore": {
    "/notes/{userId}": {
      "schema": {
        "$ref": "#/entities/Note"
      },
      "description": "Stores user notes individually"
    }
  }
}
